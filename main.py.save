from engine import check_engine
from battery import check_battery
from starter import check_starter

def main():
    while True:
        print("\n=== Car Diagnostic System 🚗 ===")
        print("1. Engine Issue")
        print("2. Battery Issue")
        print("3. Starter Issue")
        print("4. Exit")

        choice = input("Select problem area: ")

        if choice == "1":
            check_engine()
        elif choice == "2":
            check_battery()
        elif choice == "3":
            check_starter()
        elif choice == "4":
            print("Exiting system...")
            break
        else:
            print("Invalid selection")

if __name__ == "__main__":
    main()
